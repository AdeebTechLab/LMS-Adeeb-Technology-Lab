# Optional SMTP overrides (defaults: smtp.gmail.com:465)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true

# Google Drive assignment uploads
# Enable Google Drive API and create an OAuth 2.0 Web Client in Google Cloud.
